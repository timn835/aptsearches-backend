{
	"TemplateName": "SendListingsTemplate",
	"TemplateContent": {
		"Subject": "Your Latest Listings",
		"Text": "Here are your latest listings.",
		"Html": "<html>\n  <body style='font-family:Arial,sans-serif;background-color:#f9f9f9;padding:20px;'>\n    <h2 style='color:#333;'>Latest Listings</h2>\n    <table style='width:800px;max-width:800px;border-collapse:collapse;background-color:#fff;box-shadow:0 2px 5px rgba(0,0,0,0.1);table-layout:fixed;'>\n      <thead>\n        <tr style='background-color:#f1f1f1;text-align:left;'>\n          <th style='width:160px;padding:8px;border-bottom:1px solid #ddd;'>Image</th>\n          <th style='width:90px;padding:8px;border-bottom:1px solid #ddd;'>Price</th>\n          <th style='width:100px;padding:8px;border-bottom:1px solid #ddd;'>Source</th>\n          <th style='width:180px;padding:8px;border-bottom:1px solid #ddd;'>Address</th>\n          <th style='width:180px;padding:8px;border-bottom:1px solid #ddd;'>Name</th>\n          <th style='width:90px;padding:8px;border-bottom:1px solid #ddd;text-align:center;'>View</th>\n        </tr>\n      </thead>\n      <tbody>\n        {{listings}}\n      </tbody>\n    </table>\n  </body>\n</html>"
	}
}
